POSTGRES_DB=werkstatt_kanban
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password

BACKEND_NODE_ENV=production
BACKEND_HOST=0.0.0.0
BACKEND_INTERNAL_PORT=4000
DATABASE_URL=postgresql://postgres:replace-with-strong-password@database:5432/werkstatt_kanban?schema=public
SESSION_SECRET=replace-with-a-long-random-session-secret
MANAGER_MODE_PASSWORD=replace-with-a-strong-manager-password
MANAGER_MODE_IDLE_MINUTES=0
TRUST_PROXY=true

CLOUDFLARE_TUNNEL_TOKEN=replace-with-your-cloudflare-tunnel-token
PUBLIC_WEB_PORT=8080
